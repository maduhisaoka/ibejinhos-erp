# Banco PostgreSQL do Supabase.
# Use a URL com pooler para Vercel. No Supabase ela costuma aparecer em:
# Project Settings > Database > Connection string > Transaction pooler
DATABASE_URL="postgresql://postgres.xxxxx:SENHA@aws-0-sa-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"

# URL direta do banco, usada somente para migrations Prisma.
# Project Settings > Database > Connection string > Direct connection
DIRECT_URL="postgresql://postgres:SENHA@db.xxxxx.supabase.co:5432/postgres"

# Senha da area interna /gestao, /admin, /estoque e /erp.
ADMIN_PASSWORD="troque-esta-senha"

# Numero que recebe os pedidos no WhatsApp. Use DDI + DDD + numero, sem sinais.
NEXT_PUBLIC_WHATSAPP_NUMBER="5511964918434"

# Configuracao de entrega.
NEXT_PUBLIC_GAS_PRICE_PER_LITER="6.20"
NEXT_PUBLIC_VEHICLE_KM_PER_LITER="28"
NEXT_PUBLIC_DELIVERY_SERVICE_FEE="6.00"
NEXT_PUBLIC_MIN_DELIVERY_FEE="8.00"

# Use true apenas para testes. Em producao, deixe false.
NEXT_PUBLIC_ALLOW_TEST_ORDERS="false"

# Deixe false enquanto nao quiser que clientes vejam a loja.
# Troque para true no dia do lancamento.
SITE_LAUNCHED="false"
NEXT_PUBLIC_SITE_LAUNCHED="false"

# URL publica do site depois do deploy.
NEXT_PUBLIC_SITE_URL="https://seudominio.com.br"
